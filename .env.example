# Copy to .env — used by packages/shared/settings (outreach) and config/settings (email monitor)
APP_NAME=Outreach Assistant
DEBUG=true
LOG_LEVEL=info

# SQLite: use one URL. Outreach bootstrap defaults to db/sdr.sqlite3 if unset in code;
# you can override explicitly:
# DATABASE_URL=sqlite:///./db/sdr.sqlite3
DATABASE_URL=sqlite:///./db/sdr.sqlite3

OPENAI_API_KEY=your_openai_api_key

AGENTMAIL_API_KEY=your_agentmail_api_key
AGENTMAIL_INBOX_ID=your_agentmail_inbox_id

# Model parameters — email monitor (intent / response agents)
INTENT_MODEL=gpt-4o-mini
INTENT_TEMPERATURE=0.1
INTENT_MAX_TOKENS=100

RESPONSE_MODEL=gpt-4o-mini
RESPONSE_TEMPERATURE=0.7
RESPONSE_MAX_TOKENS=800

# Optional outreach tuning (packages/shared/settings)
# MAX_EMAILS_PER_LEAD=5
# MAX_WORDS_PER_EMAIL=200
# TONE=professional
# FORBIDDEN_PHRASES=guaranteed ROI,100% guarantee,no risk
